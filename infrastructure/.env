# ===========================================
# CasinoR Crash Game — Environment Variables
# ===========================================
# Copy this file to .env and fill in real values

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production

# MongoDB
MONGO_URL=mongodb://mongodb:27017/crashgame
MONGO_INITDB_DATABASE=crashgame

# Redis
REDIS_URL=redis://redis:6379

# Crypto Service (internal)
CRYPTO_SERVICE_URL=http://crypto-service:3002

# API Server
API_PORT=3001

# Game Server
GAME_PORT=3000

# Crypto Service
CRYPTO_PORT=3002

# Game Config
BETTING_PHASE_MS=7000
COOLDOWN_PHASE_MS=3000
TICK_INTERVAL_MS=50
HOUSE_EDGE_DIVISOR=33
GROWTH_RATE=0.00006

# Limits
MIN_BET=100
MAX_BET=1000000
CHAT_RATE_LIMIT_MS=2000
